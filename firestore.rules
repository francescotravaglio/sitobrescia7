rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /iscrizioni/{doc}     { allow read, write: if true; }
    match /informazioni/{doc}   { allow read, write: if true; }
    match /pre_iscrizioni/{doc} { allow read, write: if true; }
    match /soci_auth/{doc}      { allow read, write: if true; }
  }
}
